{
  "name": "copy-project-tree",
  "displayName": "Copy Project Tree",
  "publisher": "BrainstormDevelopment",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brainstorm-Development/copy-project-tree"
  },
  "description": "Copy clean project and folder tree structures to your clipboard or a file.",
  "icon": "icon.webp",
  "version": "2.0.0",
  "license": "MIT",
  "homepage": "https://github.com/Brainstorm-Development/copy-project-tree#readme",
  "bugs": {
    "url": "https://github.com/Brainstorm-Development/copy-project-tree/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "tree",
    "project tree",
    "folder tree",
    "clipboard",
    "markdown",
    "json"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:extension.copyProjectTree",
    "onCommand:extension.copyFolderTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.copyProjectTree",
        "title": "Copy Project Tree Structure"
      },
      {
        "command": "extension.copyFolderTree",
        "title": "Copy Folder Tree Structure"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.copyProjectTree",
          "when": "explorerViewletFocus && resourceUri == null",
          "group": "navigation"
        },
        {
          "command": "extension.copyFolderTree",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Copy Project Tree Configuration",
      "properties": {
        "copyProjectTree.excludedFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional file or folder names to exclude. Default exclusions include node_modules, .git, out, build, dist, and common cache folders."
        },
        "copyProjectTree.excludedPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob-like patterns to exclude from the tree. Use * for one path segment and ** for nested paths, for example docs/** or *.log."
        },
        "copyProjectTree.maxDepth": {
          "type": "number",
          "default": -1,
          "description": "Maximum depth for the tree structure. Use -1 for no limit."
        },
        "copyProjectTree.includeHidden": {
          "type": "boolean",
          "default": false,
          "description": "Include hidden files and folders in the tree structure."
        },
        "copyProjectTree.includeFiles": {
          "type": "boolean",
          "default": true,
          "description": "Include files in the tree structure. Disable this to copy folders only."
        },
        "copyProjectTree.includeRoot": {
          "type": "boolean",
          "default": false,
          "description": "Include the selected project or folder name as the first line in plain text and Markdown output."
        },
        "copyProjectTree.sortOrder": {
          "type": "string",
          "enum": [
            "foldersFirst",
            "alphabetical"
          ],
          "default": "foldersFirst",
          "description": "Sort entries with folders first or all entries alphabetically."
        },
        "copyProjectTree.outputFormat": {
          "type": "string",
          "enum": [
            "plain",
            "markdown",
            "json"
          ],
          "default": "plain",
          "description": "Output format for the tree structure. Options: plain, markdown, json."
        },
        "copyProjectTree.copyToFile": {
          "type": "boolean",
          "default": false,
          "description": "If true, save the tree structure to a file instead of copying it to the clipboard."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node --test out/test/**/*.test.js",
    "package": "vsce package",
    "publish:marketplace": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
